# ============================================================
# Global Barter Commerce — Environment Variables Template
# Copy this file to .env and fill in your actual values
# ============================================================

# ── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── Session ─────────────────────────────────────────────────
SESSION_SECRET=<random-32-char-string>

# ── Cloudflare R2 (Image Storage) ───────────────────────────
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
# Format: https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET_NAME=barter-media
# Public URL (enable via Cloudflare Dashboard → R2 → Settings → Public Access)
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# ── Cloudflare Account ───────────────────────────────────────
# Get from: Cloudflare Dashboard → Overview (right sidebar)
CLOUDFLARE_ACCOUNT_ID=<your-account-id>
# Get from: Cloudflare → My Profile → API Tokens
CLOUDFLARE_API_TOKEN=<your-api-token>

# ── Cloudflare Workers Edge Proxy ────────────────────────────
# URL of your deployed Workers (after running wrangler deploy)
EDGE_PROXY_URL=https://edge-proxy.<your-subdomain>.workers.dev
# Shared secret between Remix and Worker (generate random string)
EDGE_PROXY_SECRET=<random-hex-64>

# ── Resend (Transactional Email) ─────────────────────────────
# Get from: resend.com → API Keys → Create API Key
RESEND_API_KEY=re_<your-resend-key>
# Must be verified domain in Resend
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Global Barter Commerce

# ── LINE Messaging API ───────────────────────────────────────
# Get from: developers.line.biz → Your Channel → Messaging API
LINE_CHANNEL_ACCESS_TOKEN=<your-channel-access-token>
LINE_CHANNEL_SECRET=<your-channel-secret>
# Admin LINE User ID for system alerts (get via LINE Developer Console)
LINE_ADMIN_USER_ID=U<your-user-id>
